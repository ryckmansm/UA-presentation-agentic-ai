{
  "name": "ua-presentation",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "node --enable-source-maps dist/src/index.js",
    "test": "jest --runInBand --testPathIgnorePatterns=\"checkout.flaky.test.ts|tests/ui/\"",
    "test:all": "jest --runInBand",
    "test:flaky": "jest --runInBand tests/integration/checkout.flaky.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --testPathIgnorePatterns=\"checkout.flaky.test.ts|tests/ui/\"",
    "ui:test": "playwright test tests/ui/checkout.ui-bugs.spec.ts --project=chromium",
    "ui:test:headed": "playwright test tests/ui/checkout.ui-bugs.spec.ts --project=chromium --headed",
    "ui:install": "playwright install chromium",
    "check": "npm run build && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
